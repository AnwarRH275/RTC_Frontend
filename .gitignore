# Ignorer les dépendances
node_modules/

# Ignorer les fichiers de build
dist/
build/
out/

# Ignorer les caches et fichiers générés
.parcel-cache/
.vite/
.vscode/
.idea/
*.log
logs/

# Ignorer les fichiers spécifiques à macOS
.DS_Store
.AppleDouble
.LSOverride

# Ignorer les fichiers de configuration locale
.env
.env.local
.env.*.local

# Ignorer les clés privées
*.pem
*.pfx
*.key
*.crt
*.cert

# Ignorer les rapports de couverture de code
coverage/
.nyc_output/

# Ignorer les fichiers de lock (optionnel selon votre workflow)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Ignorer les fichiers de test
*.test.js
*.spec.js
__tests__/
test-results/

# Ignorer les fichiers temporaires et de sauvegarde
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# Ignorer les archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Ignorer les fichiers audio et vidéo
*.mp3
*.wav
*.ogg
*.m4a
*.aac
*.flac
*.mp4
*.avi
*.mov
*.wmv

# Ignorer les fichiers de cache
.cache/
.eslintcache
.stylelintcache

# Ignorer les fichiers de debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Ignorer les fichiers de profiling
*.cpuprofile
*.heapprofile

# Ignorer les fichiers de documentation générés
docs/build/
storybook-static/

# Ignorer les fichiers de déploiement
.vercel/
.netlify/