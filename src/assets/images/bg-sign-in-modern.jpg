<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0062E6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#33AEFF;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad2" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#0062E6;stop-opacity:0.7" />
      <stop offset="100%" style="stop-color:#33AEFF;stop-opacity:0.7" />
    </linearGradient>
    <filter id="blur" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="30" />
    </filter>
  </defs>
  
  <!-- Background gradient -->
  <rect width="100%" height="100%" fill="url(#grad1)" />
  
  <!-- Abstract shapes -->
  <g filter="url(#blur)">
    <circle cx="300" cy="300" r="250" fill="#ffffff" opacity="0.1" />
    <circle cx="1600" cy="800" r="300" fill="#ffffff" opacity="0.1" />
    <circle cx="1000" cy="400" r="200" fill="#ffffff" opacity="0.1" />
    <path d="M0,600 Q480,800 960,600 T1920,600 V1080 H0 Z" fill="url(#grad2)" opacity="0.6" />
  </g>
  
  <!-- Maple leaf symbol (representing Canada) -->
  <g transform="translate(960, 540) scale(0.8)" opacity="0.15">
    <path d="M0,0 L0,-35 C-9,-37 -10,-40 -15,-40 C-20,-40 -20,-37 -30,-35 L-30,-25 C-30,-25 -27,-28 -25,-28 C-23,-28 -20,-25 -20,-25 L-20,-15 C-20,-15 -25,-18 -30,-15 C-35,-12 -40,-5 -40,0 C-40,5 -35,12 -30,15 C-25,18 -20,15 -20,15 L-20,25 C-20,25 -23,28 -25,28 C-27,28 -30,25 -30,25 L-30,35 C-20,37 -20,40 -15,40 C-10,40 -9,37 0,35 L0,0 Z" fill="#ffffff" />
    <path d="M0,0 L0,-35 C9,-37 10,-40 15,-40 C20,-40 20,-37 30,-35 L30,-25 C30,-25 27,-28 25,-28 C23,-28 20,-25 20,-25 L20,-15 C20,-15 25,-18 30,-15 C35,-12 40,-5 40,0 C40,5 35,12 30,15 C25,18 20,15 20,15 L20,25 C20,25 23,28 25,28 C27,28 30,25 30,25 L30,35 C20,37 20,40 15,40 C10,40 9,37 0,35 L0,0 Z" fill="#ffffff" />
  </g>
  
  <!-- Subtle grid pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#ffffff" stroke-width="0.5" opacity="0.05" />
  </pattern>
  <rect width="100%" height="100%" fill="url(#grid)" />
  
  <!-- Text elements -->
  <text x="960" y="200" font-family="Arial, sans-serif" font-size="60" font-weight="bold" text-anchor="middle" fill="#ffffff" opacity="0.1">RÉUSSIR TCF CANADA</text>
  <text x="960" y="260" font-family="Arial, sans-serif" font-size="30" text-anchor="middle" fill="#ffffff" opacity="0.1">Votre succès commence ici</text>
</svg>